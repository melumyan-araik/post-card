/* shared functional */

$(document).ready(function () {
    var _w = $(window).width();
    if(_w<991) {

        $('.open-btn img').click(function () {
            $(this).fadeOut();
            startAnimation();
        });
    }
    else
    {
        myHandler();
    }
    function startAnimation() {
        // 1. Show back of envelope smoothly
        setTimeout(
            function () {
                // 1.1 Hide front envelope


                    // 2. Move envelope down
                    var envHeight = $('#envelope-front').height();
                    var downHeight = parseInt(envHeight * 0.67);

                    var $elem = $('.envelop-rotate');

                    $({deg: 0}).animate({deg: 90}, {
                        duration: 400,
                        step: function (now) {

                            $elem.css({
                                transform: 'rotateX(' + now + 'deg)'
                            });
                        },
                        complete: function () {
                            $('#envelope-back').addClass('envelope--open');
                            $({deg: 90}).animate({deg: 180}, {
                                duration: 400,
                                step: function (now) {

                                    $elem.css({
                                        transform: 'rotateX(' + now + 'deg)'
                                    });
                                },
                                complete: function () {
                                    setTimeout(function () {
                                        $('.envelope-flaps').css('z-index', '5');
                                        $('#gift-card').css('overflow', 'visible').css('z-index', '4');

                                        setTimeout(function () {
                                            $('.envelope-flaps').css('display', 'none');
                                        }, 2001);
                                    });
                                    $('#gift-card').animate(

                                        {top: '-500px'}
                                    );
                                    $('.envelope-flaps, .envelop-rotate').animate(
                                        // { top: '-' + (downHeight + additional) + 'px' },
                                        {
                                            top: '300px',
                                            opacity: 0
                                        }, 1000
                                    )
                                }
                            });
                        }
                    });


                    //
                    $('#envelope-back').animate(
                        {top: 500 + 'px'}, 1000
                    );



            },
            200
        );

    }


// document.getElementById('video').addEventListener('ended', myHandler, false);



function myHandler(e) {

    // What you want to do after the event
    // $("#video").hide();
    $(".animation-block").show();
    $('.open-btn img').click(function () {
        startAnimation();
        $(this).fadeOut();
    });


    function startAnimation() {


        // 1. Show back of envelope smoothly
        setTimeout(
            function () {
                    // 2. Move envelope down
                    var envHeight = $('#envelope-front').height();
                    var downHeight = parseInt(envHeight * 0.67);





                            // 3. Hide flap-up
                            // $('#envelope-back').removeClass('envelope--close');
                            // $('#envelope-back').addClass('envelope--open');
                            var $elem = $('.envelop-rotate');

                            $({deg: 0}).animate({deg: 90}, {
                                duration: 400,
                                step: function (now) {
                                    // in the step-callback (that is fired each step of the animation),
                                    // you can use the `now` paramter which contains the current
                                    // animation-position (`0` up to `angle`)
                                    $elem.css({
                                        transform: 'rotateX(' + now + 'deg)'
                                    });
                                },
                                complete: function () {
                                    $('#envelope-back').addClass('envelope--open');
                                    $({deg: 90}).animate({deg: 180}, {
                                        duration: 400,
                                        step: function (now) {
                                            // in the step-callback (that is fired each step of the animation),
                                            // you can use the `now` paramter which contains the current
                                            // animation-position (`0` up to `angle`)
                                            $elem.css({
                                                transform: 'rotateX(' + now + 'deg)'
                                            });
                                        },
                                        complete: function () {
                                            setTimeout(function () {
                                                $('.envelope-flaps').css('z-index', '5');
                                                $('#gift-card').css('overflow', 'visible').css('z-index', '4')

                                                setTimeout(function () {
                                                    $('.envelope-flaps').css('display', 'none');
                                                }, 1000);
                                            });
                                            $('#gift-card').animate(
                                                // { top: '-' + (downHeight + additional) + 'px' },
                                                {top: '-450px'}
                                            );
                                            $('.envelope-flaps, .envelop-rotate').animate(
                                                // { top: '-' + (downHeight + additional) + 'px' },
                                                {
                                                    top: '500px',
                                                    opacity: 0
                                                }, 500
                                            )
                                        }
                                    });
                                }
                            });


                            //
                            $('#envelope-back').animate(
                                {top: 500 + 'px'}, 1000
                            );

            },
            200
        );
    }
}

    setTimeout(function() {
        $('.animation-block').removeClass('hide').addClass('bounceInLeft animated');
        setTimeout(function() {
            $('#_jsi_tooltip-holder').addClass('hover');
        }, 4000);
    }, 1000);

    // Masked input
//    $('.phone-input').mask('+7 (999) 999-9999');
//            var patt = /^\+7 \(\d{3}\) \d{3}\-\d{4}$/i;

    var patt = /^\+7 \d{3} \d{3}\-\d{4}$/i;

    if ( $('#_jsi_gc_phone_input').length ) {
        var phone_input = new Cleave('#_jsi_gc_phone_input', {
            prefix: '+7',
//            noImmediatePrefix: true,
            blocks: [2, 3, 3, 4],
            delimiters: [' ', ' ', '-'],
            numericOnly: true,
            onValueChanged: function (e) {
                if ( patt.test(e.target.value) == false ) {
                    $('#_jsi_gc_btn_phone_submit').addClass('disabled');
                } else {
                    $('#_jsi_gc_btn_phone_submit').removeClass('disabled');
                }

                $('#_jsi_gc_phone_dummy').val(e.target.value);
            }
        });
        phone_input.setRawValue($('#_jsi_gc_phone_input').data('phone'));
    }

    $('._jsc_gc_input').on('focusout change', function () {
        if ( $(this).val() != '' ) {
            $(this).addClass('focus');
        } else {
            $(this).removeClass('focus');
        }
    });
    $('._jsc_gc_input').change();

    $('#_jsi_gc_btn_open_phone_block').on('click', function () {
        $(this).slideUp('slow');
        $('#_jsi_gc_phone_block').slideDown('slow');
    });

    $('#_jsi_gc_btn_phone_submit').on('click', function () {
        $('#_jsi_gc_form_send_pin').submit();
    });

    var is_sending_phone = false;

    $('#_jsi_gc_form_send_pin').on('submit', function () {

        var phone = $('#_jsi_gc_phone_input').val(),
            act_code = $(this).data('act_code');

        if ( patt.test(phone) == false || is_sending_phone ) {
            return false;
        }

        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/partner/card/sendPin",
            data: {
                receiver_mobile: phone,
                item_activation_code: act_code
            },
            beforeSend : function (xhr) {
                $('#_jsi_gc_phone_error').text('');
                $('#_jsi_gc_phone_block').addClass('sending');

                is_sending_phone = true;
            },
            complete: function (jqXHR, textStatus) {
                is_sending_phone = false;
                $('#_jsi_gc_phone_block').removeClass('sending');
            },
            success: function(data) {
                if ( data.success == 1 ) {
                    $('#_jsi_gc_phone_block').fadeOut('slow', function() {
                        $('#_jsi_gc_form_use_card_block').slideDown('slow');
                    });

                    $('#_jsi_gc_buttons_block').slideDown('slow');

                } else if ( data.error == 1 ) {
                    $('#_jsi_gc_phone_error').text(data.error_msg);
                }
            }
        });

        return false;
    });

    $('#_jsi_gc_btn_resend_sms').on('click', _.throttle(function () {
        $('#_jsi_gc_btn_resend_sms').addClass('disabled');
        $('#_jsi_gc_form_send_pin').submit();
        setTimeout(function() {
            $('#_jsi_gc_btn_resend_sms').removeClass('disabled');
        }, 30000);
    }, 30000, { 'trailing': false }));

    $('#_jsi_gc_pin').on('input change', function () {
        if ( $(this).val() == '' ) {
            $('#_jsi_gc_form_use_card_submit').addClass('disabled');
        } else {
            $('#_jsi_gc_form_use_card_submit').removeClass('disabled');
        }
    });
    $('#_jsi_gc_pin').change();

    $('#_jsi_gc_form_use_card_submit').on('click', function () {
        $('#_jsi_gc_form_use_card').submit();
    });

    var is_checking_pin = false;

    $('#_jsi_gc_form_use_card').on('submit', function () {

        var pin = $('#_jsi_gc_pin').val(),
            act_code = $(this).data('act_code');

        if ( pin == '' || is_checking_pin ) {
            return false;
        }

        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/partner/card/checkPin",
            data: {
                pin: pin,
                activation_code: act_code
            },
            beforeSend : function (xhr) {
                $('#_jsi_gc_phone_error').text('');
                $('#_jsi_gc_form_use_card_block').addClass('sending');

                is_checking_pin = true;
            },
            complete: function (jqXHR, textStatus) {
                is_checking_pin = false;
                $('#_jsi_gc_form_use_card_block').removeClass('sending');
            },
            success: function(data) {
                if ( data.success == 1 ) {
                    window.location.href = data.url;
                } else {
                    $('#_jsi_gc_phone_error').text(data.error);
                }
            }
        });

        return false;
    });



    if ( $('#_jsi_gc_phone_inp').length ) {
        var phone_input = new Cleave('#_jsi_gc_phone_inp', {
            prefix: '+7',
//            noImmediatePrefix: true,
            blocks: [2, 3, 3, 4],
            delimiters: [' ', ' ', '-'],
            numericOnly: true,
        });
    }

    if ( $('#_jsi_gc_manual_activate_inp').length ) {
        var phone_input = new Cleave('#_jsi_gc_manual_activate_inp', {
            prefix: '+7',
//            noImmediatePrefix: true,
            blocks: [2, 3, 3, 4],
            delimiters: [' ', ' ', '-'],
            numericOnly: true,
        });
    }

    $('.phone-input')
        .on('focus', function () {
            $parent = $(this).parent('.phone-tab');
            $('input[type="submit"]',$parent).fadeIn();

            $('#_jsi_gc_phone_error').text('');
        })
        .on('focusout', function () {

            if ( patt.test($(this).val()) == false ) {
                $parent = $(this).parent('.phone-tab');
                $('input[type="submit"]', $parent).fadeOut();
            }
        });

    $('#_jsi_gc_get_pin').on('click', function () {
        $('#_jsi_gc_multi_info').fadeOut('slow');
        $(this).fadeOut('slow', function() {
            $('#_jsi_gc_phone_block').fadeIn('slow');
            $('#_jsi_gc_phone_label').fadeIn('slow');
            $('#_jsi_gc_phone_inp').focus();
        });
    });

    $('#_jsi_gc_manual_activate_btn').on('click', function () {
        $('#_jsi_gc_multi_info').fadeOut('slow');
        $(this).fadeOut('slow', function() {
            $('#_jsi_gc_manual_activate_block').fadeIn('slow');
            $('#_jsi_gc_manual_activate_label').fadeIn('slow');
            $('#_jsi_gc_manual_activate_inp').focus();
        });
    });

    var is_sending = false;

    $('#_jsi_gc_send_pin').on('submit', function () {

        if ( patt.test($('.phone-input').val()) == false ) {
            return false;
        }

        if ( is_sending ) {
            return false;
        }

        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/partner/card/sendPin",
            data: {
                receiver_mobile: $('.phone-input').val(),
                item_activation_code: $('.phone-input').data('act_code')
            },
            beforeSend : function (xhr) {
                $('#_jsi_gc_phone_error').text('');
                $('#_jsi_gc_phone_block').addClass('sending');

                is_sending = true;
            },
            complete: function (jqXHR, textStatus) {
                is_sending = false;
                $('#_jsi_gc_phone_block').removeClass('sending');
            },
            success: function(data) {
                if ( data.success == 1 ) {
                    $('#_jsi_gc_card_info').fadeOut('slow', function() {
                        $('#_jsi_gc_get_pin_success').fadeIn('slow');
                        $('#_jsi_gc_get_pin_success_grats').fadeIn('slow');
                    });

                    $('#_jsi_gc_buttons_block').slideDown('slow');

                } else if ( data.error == 1 ) {
                    $('#_jsi_gc_phone_error').text(data.error_msg);
                }
            }
        });

        return false;
    });

    $('#_jsi_gc_manual_activate_form').on('submit', function () {

        var phone = $('#_jsi_gc_manual_activate_inp').val(),
            act_code = $('#_jsi_gc_manual_activate_inp').data('act_code');

        if ( patt.test(phone) == false ) {
            return false;
        }

        if ( is_sending ) {
            return false;
        }

        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/partner/card/manualActivate",
            data: {
                receiver_mobile: phone,
                item_activation_code: act_code
            },
            beforeSend : function (xhr) {
                $('#_jsi_gc_manual_activate_error').text('');
                $('#_jsi_gc_manual_activate_block').addClass('sending');

                is_sending = true;
            },
            complete: function (jqXHR, textStatus) {
                is_sending = false;
                $('#_jsi_gc_manual_activate_block').removeClass('sending');
            },
            success: function(data) {
                if ( data.success == 1 && data.cardInfo !== undefined ) {

                    $('#_jsi_gc_manual_activate_success_barcode').attr('src', data.cardInfo.barcode);
                    $('#_jsi_gc_manual_activate_success_number').html(data.cardInfo.number);
                    $('#_jsi_gc_manual_activate_success_dates').html(data.cardInfo.start_date + ' - ' + data.cardInfo.end_date);

                    $('#_jsi_gc_card_info').fadeOut('slow', function() {
                        $('#_jsi_gc_manual_activate_success').fadeIn('slow');
                        $('#_jsi_gc_manual_activate_success_grats').fadeIn('slow');
                    });

                    $('#_jsi_gc_buttons_block').slideDown('slow');

                } else if ( data.error == 1 ) {
                    $('#_jsi_gc_manual_activate_error').text(data.error_msg);
                }
            }
        });

        return false;
    });

    if ( $('._jsc_copy_by_click').length ) {
        var clipboard = new ClipboardJS('._jsc_copy_by_click', {
            target: function(trigger) {
                return $(trigger).find('._jsc_copy_by_click_target').get(0);
            }
        });

        clipboard.on('success', function(e) {
            $(document).focusout();
            e.clearSelection();

            $('#_jsi_copy_success').slideDown('slow', function () {
                var elem = $(this);
                setTimeout(function () {
                    elem.slideUp('slow');
                }, 1500);
            });
        });
    }

    $('#_jsi_gc_captcha_form').on('submit', function () {
        $.ajax({
            type: "POST",
            dataType: "json",
            url: $(this).prop('action'),
            data: $(this).serialize(),
            beforeSend : function (xhr) {
                $('#_jsi_gc_captcha_form_error').text('');
            },
            complete: function (jqXHR, textStatus) {
            },
            success: function(data) {
                if ( data.success ) {
                    location.reload();
                } else {
                    $('#_jsi_gc_captcha_form_error').text(data.message);
                }
            }
        });
        return false;
    });
    
    // is mobile
    if ((/(android|bb\d+|meego).+mobile|avantgo|bada\/|blackberry|blazer|compal|elaine|fennec|hiptop|iemobile|ip(hone|od)|ipad|iris|kindle|Android|Silk|lge |maemo|midp|mmp|netfront|opera m(ob|in)i|palm( os)?|phone|p(ixi|re)\/|plucker|pocket|psp|series(4|6)0|symbian|treo|up\.(browser|link)|vodafone|wap|windows (ce|phone)|xda|xiino/i.test(navigator.userAgent)
        || /1207|6310|6590|3gso|4thp|50[1-6]i|770s|802s|a wa|abac|ac(er|oo|s\-)|ai(ko|rn)|al(av|ca|co)|amoi|an(ex|ny|yw)|aptu|ar(ch|go)|as(te|us)|attw|au(di|\-m|r |s )|avan|be(ck|ll|nq)|bi(lb|rd)|bl(ac|az)|br(e|v)w|bumb|bw\-(n|u)|c55\/|capi|ccwa|cdm\-|cell|chtm|cldc|cmd\-|co(mp|nd)|craw|da(it|ll|ng)|dbte|dc\-s|devi|dica|dmob|do(c|p)o|ds(12|\-d)|el(49|ai)|em(l2|ul)|er(ic|k0)|esl8|ez([4-7]0|os|wa|ze)|fetc|fly(\-|_)|g1 u|g560|gene|gf\-5|g\-mo|go(\.w|od)|gr(ad|un)|haie|hcit|hd\-(m|p|t)|hei\-|hi(pt|ta)|hp( i|ip)|hs\-c|ht(c(\-| |_|a|g|p|s|t)|tp)|hu(aw|tc)|i\-(20|go|ma)|i230|iac( |\-|\/)|ibro|idea|ig01|ikom|im1k|inno|ipaq|iris|ja(t|v)a|jbro|jemu|jigs|kddi|keji|kgt( |\/)|klon|kpt |kwc\-|kyo(c|k)|le(no|xi)|lg( g|\/(k|l|u)|50|54|\-[a-w])|libw|lynx|m1\-w|m3ga|m50\/|ma(te|ui|xo)|mc(01|21|ca)|m\-cr|me(rc|ri)|mi(o8|oa|ts)|mmef|mo(01|02|bi|de|do|t(\-| |o|v)|zz)|mt(50|p1|v )|mwbp|mywa|n10[0-2]|n20[2-3]|n30(0|2)|n50(0|2|5)|n7(0(0|1)|10)|ne((c|m)\-|on|tf|wf|wg|wt)|nok(6|i)|nzph|o2im|op(ti|wv)|oran|owg1|p800|pan(a|d|t)|pdxg|pg(13|\-([1-8]|c))|phil|pire|pl(ay|uc)|pn\-2|po(ck|rt|se)|prox|psio|pt\-g|qa\-a|qc(07|12|21|32|60|\-[2-7]|i\-)|qtek|r380|r600|raks|rim9|ro(ve|zo)|s55\/|sa(ge|ma|mm|ms|ny|va)|sc(01|h\-|oo|p\-)|sdk\/|se(c(\-|0|1)|47|mc|nd|ri)|sgh\-|shar|sie(\-|m)|sk\-0|sl(45|id)|sm(al|ar|b3|it|t5)|so(ft|ny)|sp(01|h\-|v\-|v )|sy(01|mb)|t2(18|50)|t6(00|10|18)|ta(gt|lk)|tcl\-|tdg\-|tel(i|m)|tim\-|t\-mo|to(pl|sh)|ts(70|m\-|m3|m5)|tx\-9|up(\.b|g1|si)|utst|v400|v750|veri|vi(rg|te)|vk(40|5[0-3]|\-v)|vm40|voda|vulc|vx(52|53|60|61|70|80|81|83|85|98)|w3c(\-| )|webc|whit|wi(g |nc|nw)|wmlb|wonu|x700|yas\-|your|zeto|zte\-/i.test(navigator.userAgent.substr(0,4)))) {
        // ios
        if (typeof window !== 'undefined' && window.navigator && window.navigator.platform && /iP(ad|hone|od)/.test(window.navigator.platform)) {
            $('#google-pay-link').hide()
        }
        // android
        // let userAgent = navigator.userAgent.toLowerCase();
        if (navigator.userAgent.toLowerCase().indexOf("android") > -1) {
            $('#apple-wallet-link').hide()
        }
    }
});

// открытие правил (подарочная карта)
async function openPopupRules () {
    const response = await fetch('/partner/index/rules');
    const json = await response.json();
    // вставляем заголовок
    const element_title = document.getElementsByClassName('modal-header1_title');
    element_title[0].innerHTML = json.title;
    // вставляем текст
    const element_body = document.getElementsByClassName('element_body');
    element_body[0].innerHTML = json.rules;
    $('.wrap1, a').toggleClass('active');
    if (window.innerWidth < 450) {
        window.scroll(0, 295);
    } else {
        window.scroll(0, 130);
    }
}

// закрытие попапа (подарочная карта)
function closePopupRulesOffer () {
    const element_title_offer = document.getElementsByClassName('modal-header1_title');
    element_title_offer[0].innerHTML = '';
    const element_body_offer = document.getElementsByClassName('element_body');
    element_body_offer[0].innerHTML = '';
    $('.wrap1, a').removeClass('active');
}

// открытие оферты (подарочная карта)
async function openPopupOffer () {
    const response_offer = await fetch('/partner/index/offer');
    const json_offer = await response_offer.json();
    // вставляем заголовок
    const element_title_offer = document.getElementsByClassName('modal-header1_title');
    element_title_offer[0].innerHTML = json_offer.title;
    // вставляем текст
    const element_body_offer = document.getElementsByClassName('element_body');
    element_body_offer[0].innerHTML = json_offer.offer;
    $('.wrap1, a').toggleClass('active');
    if (window.innerWidth < 450) {
        window.scroll(0, 295);
    } else {
        window.scroll(0, 130);
    }

}

function addTermsOfferRulesVisible() {
    document.getElementById('terms_offer_rules_display').classList.add('terms_offer_rules_display_none');
}